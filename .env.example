DISCORD_TOKEN=""
PREFIX="!"
DB=""
DEV=""
OLDLOBBY=""
VERSION=""

# Sentry
# DSN that receives error events. Leave empty to disable Sentry.
SENTRY_DSN=""
# Base issues URL (ends with query=) that logs.py appends an event id to for a clickable link.
SENTRY_URL="https://your-org.sentry.io/issues/?query="

# Logging (optional; defaults shown)
LOG_LEVEL="INFO"
LOG_FLUSH_INTERVAL="10"
LOG_BUFFER_CAPACITY="5000"